generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Region {
  id        String          @id @default(uuid())
  name      String
  slug      String          @unique
  state     String?
  isActive  Boolean         @default(true)
  products  ProductRegion[]
  createdAt DateTime        @default(now())
}

model Brand {
  id       String    @id @default(uuid())
  name     String
  slug     String    @unique
  products Product[]
}

model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  imageUrl  String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id           String          @id @default(uuid())
  name         String
  description  String
  price        Float
  imageUrl     String
  categoryId   String
  category     Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  brandId      String?
  brand        Brand?          @relation(fields: [brandId], references: [id], onDelete: SetNull)
  badge        String?
  isFeatured   Boolean         @default(false)
  isBestSeller Boolean         @default(false)
  inStock      Boolean         @default(true)
  flavors      ProductFlavor[]
  regions      ProductRegion[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model ProductFlavor {
  id          String  @id @default(uuid())
  productId   String
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String
  description String?
  inStock     Boolean @default(true)
  order       Int     @default(0)
}

model ProductRegion {
  id        String  @id @default(uuid())
  productId String
  regionId  String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  region    Region  @relation(fields: [regionId], references: [id], onDelete: Cascade)
  inStock   Boolean @default(true)

  @@unique([productId, regionId])
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String?  @unique
  phone     String?  @unique
  createdAt DateTime @default(now())
}

model Banner {
  id        String   @id @default(uuid())
  title     String
  subtitle  String?
  imageUrl  String
  linkUrl   String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Order {
  id             String   @id @default(uuid())
  customerName   String
  customerPhone  String
  regionSlug     String?
  deliveryMethod String   @default("whatsapp")
  address        String?
  itemsJson      String
  totalPrice     Float
  status         String   @default("Pendente")
  createdAt      DateTime @default(now())
}

model SiteSettings {
  id             String   @id @default("default")
  whatsappNumber String   @default("5511999999999")
  instagramUrl   String   @default("https://instagram.com/sabor.gold")
  facebookUrl    String?
  address        String   @default("São Paulo - SP")
  contactEmail   String   @default("contato@saborgold.com")
  heroTitle      String   @default("MAIS QUE SABOR, UMA EXPERIÊNCIA.")
  heroSubtitle   String   @default("Selecione sua região e explore pods e vapes premium.")
  aboutText      String   @default("Sabor Gold — curadoria premium de vapes e pods.")
  updatedAt      DateTime @updatedAt
}
