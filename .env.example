# ─── Banco de Dados (Supabase PostgreSQL) ─────────────────────────────────────
# Supabase → Project Settings → Database → Connection string
# Use Transaction Pooler para produção (Vercel):
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Use Direct URL para migrações (Prisma Migrate):
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[REGION].pooler.supabase.com:6543/postgres"

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD="saborgold2026"

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."
# Service Role Key — necessária para upload/delete de imagens no Storage
# Obtenha em: https://supabase.com/dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."
